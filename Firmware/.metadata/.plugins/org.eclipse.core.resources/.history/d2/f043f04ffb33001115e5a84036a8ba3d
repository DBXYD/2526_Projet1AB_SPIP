/* USER CODE BEGIN 4 */
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin) {
    if (GPIO_Pin == us_sensor.ECHO_Pin) {
        if (HAL_GPIO_ReadPin(us_sensor.ECHO_Port, us_sensor.ECHO_Pin) == GPIO_PIN_SET) {
            __HAL_TIM_SET_COUNTER(us_sensor.htim, 0);
            HAL_TIM_Base_Start(us_sensor.htim);
            us_sensor.echo_start = __HAL_TIM_GET_COUNTER(us_sensor.htim);
        } else {
            us_sensor.echo_end = __HAL_TIM_GET_COUNTER(us_sensor.htim);
            HAL_TIM_Base_Stop(us_sensor.htim);

        }
    }
    US_Update(&us_sensor);

}

void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim) {
	if (htim == &htim6) {
		US_Trigger(&us_sensor);
		LF_Update(&h_lineFollower);

		encoder_update(&encoder_left);
	    encoder_update(&encoder_right);
		control_update(&control_left,&motor_left, &encoder_left);
		control_update(&control_right,&motor_right, &encoder_right);
		move_update(&move, &control_left,&control_right, &encoder_left, &encoder_right);
		if (reset == 40){
			error_reset(&control_left);
			error_reset(&control_right);
			reset = 0;
		}
		reset++;
	}
}
