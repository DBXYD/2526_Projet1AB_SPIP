#include "mouvement.h"

extern MOTOR * motor_d;
extern MOTOR * motor_g;
extern ENCODER * encoder_d;
extern ENCODER * encoder_g;

MOUVEMENTCONTROL mvt;


void move_init(MOUVEMENTCONTROL mvt){
	mvt.etat=STOP;
	mvt.distance_ticks_cible=0;
	mvt.distance_ticks_d_parcourue=0;
	mvt.distance_ticks_g_parcourue=0;
	mvt.vitesse_ticks_ms=0;
}

void stop() {
    mvt.etat = STOP;
    asservissement_set_vitesse(0, 0);
}

void avancer(float distance_m, float vitesse) {
    float perimetre = 2.0f * M_PI * motor_g->rayon/ 1000.0f ;  // le /1000.0 f c'est pour des mm
    float ticks_par_mm = encoder_g->tick_tour / perimetre;
    mvt.distance_ticks_cible = (int32_t)(distance_m * ticks_par_mm);// le /1000.0 f c'est pour des ms
    mvt.vitesse_ticks_ms = (vitesse* ticks_par_mm) / 1000.0f;
	mvt.distance_ticks_d_parcourue=0;
	mvt.distance_ticks_g_parcourue=0;

    encoder_d->compteur = 0;
    encoder_g->compteur = 0;
    mvt.etat = AVANCER;
}

void tourner(float angle_deg, float vitesse) {
    float perimetre_roue = 2.0f * M_PI * motor_g->rayon/ 1000.0f;
    float ticks_par_mm = encoder_g->tick_tour / perimetre_roue;
    float angle_rad = fabsf(angle_deg) * M_PI / 180.0f;
	float arc_mm = angle_rad * (DISTANCE_DISTANCE_ROUE / 2.0f);

    mvt.distance_ticks_cible = (int32_t)(arc_mm * ticks_par_mm);
    mvt.vitesse_ticks_ms = (vitesse * ticks_par_mm) / 1000.0f;
	mvt.angle_positif = (angle_deg > 0);
	mvt.distance_ticks_d_parcourue=0;
	mvt.distance_ticks_g_parcourue=0;

    encoder_d->compteur = 0;
    encoder_g->compteur = 0;
    mvt.etat = TOURNER;
}

void mouvement_update_task() {
    if (mvt.etat == STOP){
    	return;
    }

    mvt.distance_ticks_g_parcourue += abs(encoder_g->compteur);
    mvt.distance_ticks_d_parcourue += abs(encoder_d->compteur);

    if (mvt.distance_ticks_g_parcourue >= mvt.distance_ticks_cible &&
        mvt.distance_ticks_d_parcourue >= mvt.distance_ticks_cible) {
        stop();
        return;
    }

        int32_t ecart = mvt.distance_ticks_g_parcourue - mvt.distance_ticks_d_parcourue;
        float Kp_sync = 0.05f; // Coefficient de correction
        float corr = ecart * Kp_sync;

       if (mvt.etat == AVANCER) {
            asservissement_set_vitesse(mvt.vitesse_ticks_ms - corr,mvt.vitesse_ticks_ms + corr);
        }
       if (mvt.etat == TOURNER) {
            if (mvt.angle_positif) {
                asservissement_set_vitesse(-(mvt.vitesse_ticks_ms - corr), (mvt.vitesse_ticks_ms + corr));
            }
            else {
                asservissement_set_vitesse( (mvt.vitesse_ticks_ms - corr), -(mvt.vitesse_ticks_ms + corr));
            }
        }
    }
