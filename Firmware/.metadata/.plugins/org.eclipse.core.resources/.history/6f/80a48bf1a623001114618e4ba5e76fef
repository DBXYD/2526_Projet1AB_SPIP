#include "mouvement.h"

extern MOTOR * motor_d;
extern MOTOR * motor_g;
extern ENCODER * encoder_d;
extern ENCODER * encoder_g;

MOUVEMENTCONTROL mvt;


void move_init(MOUVEMENTCONTROL mvt){
	mvt.etat=STOP;
	mvt.distance_ticks_cible=0;
	mvt.distance_ticks_parcourue=0;
	mvt.vitesse_ticks_ms=0;
}

void stop() {
    mvt.etat = STOP;
    asservissement_set_vitesse(0, 0);
}

void avancer(float distance_m, float vitesse) {
    float perimetre = 2.0f * M_PI * motor_g->rayon/ 1000.0f ;  // le /1000.0 f c'est pour des mm
    float ticks_par_mm = encoder_g->tick_tour / perimetre;
    mvt.distance_ticks_cible = (int32_t)(distance_m * ticks_par_mm);// le /1000.0 f c'est pour des ms
    mvt.vitesse_ticks_ms = (vitesse* ticks_par_mm) / 1000.0f;
    mvt.distance_ticks_parcourue = 0;

    encoder_d->compteur = 0;
    encoder_g->compteur = 0;
    mvt.etat = AVANCER;
}

void tourner(float angle_deg, float vitesse_ms) {
    float perimetre_roue = 2.0f * M_PI * motor_g->rayon/ 1000.0f;
    float ticks_par_metre = encoder_g->tick_tour / perimetre_roue;
    float arc_m = (angle_deg * M_PI * DISTANCE_ROUE) / 360.0f;

    mvt.distance_ticks_cible = (int32_t)(arc_m * ticks_par_metre);
    mvt.vitesse_ticks_ms = (vitesse_ms * ticks_par_metre) / 1000.0f;
    mvt.distance_ticks_parcourue = 0;

    encoder_d->compteur = 0;
    encoder_g->compteur = 0;
    mvt.etat = TOURNER;
}

void mouvement_update_task() {
    if (mvt.etat == STOP){
    	return;
    }

    // 1. On CUMULE la distance parcourue depuis la dernière milliseconde
    // (Avant que asservissement_update ne remette les compteurs à 0)
    int32_t delta_ticks = (abs(encoder_d->compteur) + abs(encoder_g->compteur)) / 2;
    mvt.distance_ticks_parcourue += delta_ticks;

    // 2. On vérifie si l'objectif est atteint
    if (mvt.distance_ticks_parcourue >= mvt.distance_ticks_cible) {
        stop();
        return;
    }

    // 3. Application des consignes
    if (mvt.etat == AVANCER) {
		asservissement_set_vitesse(mvt.vitesse_ticks_ms, mvt.vitesse_ticks_ms);
	}
	else if (mvt.etat == TOURNER) {
        // Pour tourner, une roue avance, l'autre recule
		if (angle_deg_demandé_etait_positif) { // À adapter si tu ajoutes le sens de rotation dans avancer()
            asservissement_set_vitesse(mvt.vitesse_ticks_ms, -mvt.vitesse_ticks_ms);
        } else {
            asservissement_set_vitesse(-mvt.vitesse_ticks_ms, mvt.vitesse_ticks_ms);
        }
	}
}
