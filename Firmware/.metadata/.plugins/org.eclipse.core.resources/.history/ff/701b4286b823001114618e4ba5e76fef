#include "asservissement.h"
#include "mouvement.h"

extern MOTOR * motor_d;
extern MOTOR * motor_g;
extern ENCODER * encoder_d;
extern ENCODER * encoder_g;
extern ASSERVISSEMENT * asservissement;
extern MOUVEMENT mvt;

void asservissement_init(ASSERVISSEMENT * asservissement,float Kp,float Ki){
	asservissement->consigne_vitesse_g=0;
	asservissement->consigne_vitesse_d=0;
	asservissement->Kp=Kp;
	asservissement->Ki=Ki;
}
void asservissement_set_vitesse(float speed_g, float speed_d) {
	asservissement->consigne_vitesse_g = speed_g;
	asservissement->consigne_vitesse_d = speed_d;
}

void asservissement_update(void) {
	encoder_update(encoder_g);
	encoder_update(encoder_d);

	int16_t mesure_g = (int16_t)encoder_g->compteur;
	int16_t mesure_d = (int16_t)encoder_d->compteur;

	if (mvt->etat != STOP) {
	        mvt->distance_ticks_g_parcourue += abs(mesure_g);
	        mvt->distance_ticks_d_parcourue += abs(mesure_d);
	    }

	encoder_g->compteur = 0;
	encoder_d->compteur = 0;

	float erreur_g = asservissement->consigne_vitesse_g - (float)mesure_g;
	float erreur_d = asservissement->consigne_vitesse_d - (float)mesure_d;

	motor_g->erreur_accumulee += erreur_g;
	motor_d->erreur_accumulee += erreur_d;

	if (motor_g->erreur_accumulee > (float)motor_g->ARR) motor_g->erreur_accumulee = (float)motor_g->ARR;
	if (motor_g->erreur_accumulee < -(float)motor_g->ARR) motor_g->erreur_accumulee = -(float)motor_g->ARR;

	if (motor_d->erreur_accumulee > (float)motor_d->ARR) motor_d->erreur_accumulee = (float)motor_d->ARR;
	if (motor_d->erreur_accumulee < -(float)motor_d->ARR) motor_d->erreur_accumulee = -(float)motor_d->ARR;

	motor_g->speed = (asservissement->Kp * erreur_g) + (asservissement->Ki * motor_g->erreur_accumulee);
	motor_d->speed = (asservissement->Kp * erreur_d) + (asservissement->Ki * motor_d->erreur_accumulee);

	CRR_security(motor_g);
	CRR_security(motor_d);
}


















