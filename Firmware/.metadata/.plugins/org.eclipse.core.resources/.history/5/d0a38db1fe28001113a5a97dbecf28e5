void mouvement_update(MVTCTRL *mvt, ASSERVISSEMENT *asser, ENCODER *encoder_g, ENCODER *encoder_d,MOTOR *motor_g,MOTOR *motor_d) {
	if (mvt->etat == STOP){
	        asser_set_speed(asser, 0, 0);
	        return;
	    }
		mvt->d_ticks_g_actual += encoder_g->delta_ticks;
	    mvt->d_ticks_d_actual += encoder_d->delta_ticks;

	    float speed_g = 0, speed_d = 0;
	    int sens_d=encoder_d->delta_ticks/abs(encoder_d->delta_ticks);
	    int sens_g=encoder_g->delta_ticks/abs(encoder_g->delta_ticks);

		if (mvt-> d_ticks_g_actual*sens_g< mvt->d_ticks_target){
			speed_g = mvt->speed_ticks;
		}

		if (mvt->d_ticks_d_actual*sens_d < mvt->d_ticks_target){
			speed_d = mvt->speed_ticks;
		}

		if (speed_g == 0 && speed_d == 0){
			mvt->etat = STOP;
		}


		if (mvt->etat == AVANCER){
			asser_set_speed(asser,motor_g,speed_g);
			asser_set_speed(asser,motor_d,speed_d);
		}
		else if (mvt->etat == TOURNER) {
			if (mvt->angle_positif){
				asser_set_speed(asser,motor_g,-speed_g);
				asser_set_speed(asser,motor_d,speed_d);			}
			else{
				asser_set_speed(asser,motor_g,speed_g);
				asser_set_speed(asser,motor_d,-speed_d);
		}
	}
}
