#include "mouvement.h"
#include<stdio.h>

void move_init(MVTCTRL * mvt,float track_width,float radius){
	mvt->etat=STOP;
	mvt->d_ticks_target=0;
	mvt->d_ticks_d_actual=0;
	mvt->d_ticks_g_actual=0;
	mvt->speed_cnt=0;
	mvt->track_width=track_width;
	mvt->radius=radius;
}


void avancer(MVTCTRL *mvt, MOTOR *motor, ENCODER *encoder,float d_target_cm, float speed_cm_s){
    float perimeter_cm = 2.0f * M_PI * mvt->radius;
    float K=(encoder->cnt_tour/perimeter);
    mvt->d_target_cnt =d_target_cm*K;
    mvt->speed_cnt = (int32_t) (speed_cm_s*K/1000) ;
	mvt->d_ticks_g_actual=0;
	mvt->d_ticks_d_actual=0;
    mvt->etat = AVANCER;

}

