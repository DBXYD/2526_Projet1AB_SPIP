#include "encoder.h"
#include <stdio.h>

void encoder_init(ENCODER * encoder, TIM_HandleTypeDef * htim_param, float tick_par_tour,int sens){
	encoder->htim =htim_param;
	encoder->delta_ticks=0;
	encoder->last_counter=0;
	encoder->tick_tour= tick_par_tour;
	encoder->sens=sens;

	HAL_TIM_Encoder_Start(htim_param, TIM_CHANNEL_ALL);
	encoder->htim->Instance->CNT=0;
}


void encoder_update(ENCODER * encoder){
	uint16_t current_val = encoder->htim->Instance->CNT;
	encoder->delta_ticks = (int16_t)(current_val - encoder->last_counter) * encoder->sens;
	encoder->last_counter = current_val;
}

void Test_Ticks_Par_Tour(ENCODER *enc_g, ENCODER *enc_d) {
    printf("\r\n--- TEST : TOUR DE ROUE ---\r\n");
    printf("Positionnez la roue sur le repere...\r\n");

    // Reset des compteurs via la structure
    enc_g->htim->Instance->CNT = 0;
    enc_d->htim->Instance->CNT = 0;
    enc_g->last_counter = 0;
    enc_d->last_counter = 0;

    printf("Tournez la roue manuellement de EXACTEMENT un tour...\r\n");

    for(int i = 0; i < 150; i++) {
        // On récupère la valeur brute du registre CNT
        int16_t count_g = (int16_t)enc_g->htim->Instance->CNT;
        int16_t count_d = (int16_t)enc_d->htim->Instance->CNT;

        // On affiche avec le sens appliqué pour avoir la valeur réelle
        printf("Ticks G: %d | Ticks D: %d\r", (int)(count_g * enc_g->sens), (int)(count_d * enc_d->sens));

        HAL_Delay(100);
    }

    printf("\nTest termine ! Relevez les valeurs.\r\n");
}
